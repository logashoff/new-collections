{
  "name": "new-collections",
  "description": "Browser extension to save and restore tabs",
  "version": "1.3",
  "private": true,
  "scripts": {
    "build:dev": "ng build --configuration development",
    "build:e2e": "ng build --configuration e2e",
    "build:service": "esbuild ./src/background.ts --legal-comments=none --bundle --outfile=./dist/new-collections/background.js",
    "build": "ng build --configuration production --output-hashing none",
    "e2e": "yarn build:e2e && yarn vitest",
    "fmt": "git diff --name-only --diff-filter=d | grep -E \"\\.ts$|\\.json$|\\.html$|\\.scss$\" | xargs prettier -w",
    "lint": "ng lint && stylelint ./src/**/*.scss",
    "postbuild:dev": "yarn build:service",
    "postbuild:e2e": "yarn build:service",
    "postbuild": "yarn build:service --minify",
    "test": "ng test"
  },
  "engines": {
    "yarn": "^1.22.17",
    "npm": "Please use Yarn instead of NPM to install dependencies. See: https://yarnpkg.com/lang/en/docs/install/"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "date-fns": "^4.4.0",
    "fuse.js": "^7.4.2",
    "lodash-es": "^4.18.1",
    "normalize-url": "^9.0.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2200.0",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-service": "^22.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ngneat/spectator": "^22.1.0",
    "@types/chrome": "^0.1.43",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "lodash": "^4.18.1",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.3",
    "puppeteer": "^25.1.0",
    "stylelint": "^17.13.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "4.1.8"
  }
}
